# ============================================================
# Thumbtack AI Agent — переменные окружения
# Скопируй в .env и заполни значения.
# НИКОГДА не коммить .env в git.
# ============================================================

# --- Thumbtack Partner API OAuth ---
THUMBTACK_CLIENT_ID=7e19ea23-5927-4d0c-bb34-8628ac4cc139
THUMBTACK_CLIENT_SECRET=your_client_secret_here

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- VAPI (звонки) ---
# ENABLE_VOICE_AGENT=false  → звонки отключены (дефолт, безопасный режим)
# ENABLE_VOICE_AGENT=true   → включить; тогда VAPI_API_KEY обязателен
ENABLE_VOICE_AGENT=false
VAPI_API_KEY=your_vapi_api_key

# --- Cloudflare KV (хранение токенов и диалогов) ---
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_API_TOKEN=your_cloudflare_api_token
CF_KV_NS_ID=your_kv_namespace_id

# --- App ---
# Оставить пустым для продакшена (дефолт: https://thumbtack-oauth.onrender.com/callback)
# REDIRECT_URI=http://localhost:8000/callback
